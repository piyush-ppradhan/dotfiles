{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "scrollbar": {
    "cursors": false,
    "diagnostics": "none",
    "git_diff": false,
    "search_results": false,
    "selected_text": false,
    "selected_symbol": false
  },
  "disable_ai":true,
  "buffer_line_height": "standard",
  "current_line_highlight": "none",
  "git": {
    "git_gutter": "hide",
    "inline_blame": { "enabled": false },
  },
  // "diagnostics": {
  //   "inline": { "enabled": true },
  // },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "inline_code_actions": false,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruvbox Dark Hard",
  },
  "gutter": {
    "line_numbers": false,
    "folds": false,
    "runnables": false,
    "breakpoints": false
  },
  "indent_guides": {
    "enabled": false,
  },
  "ui_font_family": "Inconsolata Nerd Font Mono",
  "buffer_font_family": "Inconsolata Nerd Font Mono",
  "ui_font_size": 17.5,
  "buffer_font_size": 17.3,
  "tab_bar": {
    "show": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "agent_review": false,
    "code_actions": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "format_on_save": "off",
  "languages": {
      "Python": {
        "language_servers": ["!basedpyright", "pyright", "ruff"],
        "format_on_save": "on",
        "formatter": {
          "language_server": {
            "name": "ruff"
          }
        }
    },
    "C": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"]
        }
      }
    },
    "C++": {
      "format_on_save": "on",
      "language_servers": ["clangd"],
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"]
        }
      }
    }
  },
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
