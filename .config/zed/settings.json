{
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "diagnostics": {
    "button": false,
    "include_warnings": false,
  },

  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Gruvbox Dark Hard",
  },
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 16,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14.5,
  "agent_buffer_font_size": 14.5,

  "buffer_line_height": "comfortable",
  "current_line_highlight": "none",
  "format_on_save": "off",
  "inline_code_actions": false,
  "vim_mode": true,

  "gutter": {
    "line_numbers": false,
    "folds": false,
    "runnables": false,
    "breakpoints": false
  },
  "indent_guides": {
    "enabled": false,
  },
  "scrollbar": {
    "cursors": false,
    "diagnostics": "none",
    "git_diff": false,
    "search_results": false,
    "selected_text": false,
    "selected_symbol": false,
    "show": "auto"
  },
  "toolbar": {
    "breadcrumbs": false,
    "agent_review": false,
    "code_actions": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
    "show_user_menu": false,
  },

  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  // "agent": {
  //   "dock": "right",
  //   "favorite_models": [],
  //   "model_parameters": []
  // },

  "git": {
    "git_gutter": "hide",
    "inline_blame": { "enabled": false },
  },
  //"disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "languages": {
    "Python": {
      "language_servers": ["!basedpyright", "pyright", "ruff"],
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      }
    },
    "C": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"]
        }
      }
    },
    "C++": {
      "format_on_save": "on",
      "language_servers": ["clangd"],
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"]
        }
      }
    }
  },
}
